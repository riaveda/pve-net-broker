#!/usr/bin/env python3
"""pnbctl — PVE Net Broker CLI control tool.

Usage:
    pnbctl status          Show service status and slave summary
    pnbctl slaves          List all slaves
    pnbctl slave <id>      Show slave detail
    pnbctl reserve <id> <requester> <vm_ip>   Reserve a slave
    pnbctl release <id>    Release a slave
    pnbctl logs [-f]       Show service logs
    pnbctl restart         Restart service
    pnbctl nat reload      Reapply static NAT rules (convergent flush+repopulate)
    pnbctl dhcp reload     Validate & reload DHCP fixed-IP config
    pnbctl proxy deploy    Deploy reverse-proxy nginx routing conf to the proxy VM
    pnbctl tz apply        Set timezone (Asia/Seoul) on PVE host + all VMs/CTs
    pnbctl version         Show version
"""

import json
import os
import subprocess
import sys
from urllib.request import urlopen, Request
from urllib.error import URLError

BROKER_URL = os.getenv("PNB_URL", "http://127.0.0.1:7100")

# ANSI colors
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
BOLD = "\033[1m"
RESET = "\033[0m"


def api_get(path: str):
    try:
        with urlopen(f"{BROKER_URL}{path}", timeout=5) as resp:
            return json.loads(resp.read())
    except URLError as e:
        print(f"{RED}ERROR:{RESET} Cannot reach broker at {BROKER_URL}")
        print(f"       {e}")
        sys.exit(1)


def api_post(path: str, data: dict = None):
    body = json.dumps(data).encode() if data else b""
    req = Request(
        f"{BROKER_URL}{path}",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urlopen(req, timeout=5) as resp:
            return json.loads(resp.read()), resp.status
    except URLError as e:
        if hasattr(e, "read"):
            err = json.loads(e.read())
            return err, e.code
        print(f"{RED}ERROR:{RESET} {e}")
        sys.exit(1)


def cmd_status():
    """Show service status + health."""
    # systemd status
    result = subprocess.run(
        ["systemctl", "is-active", "pve-net-broker"],
        capture_output=True, text=True,
    )
    svc_status = result.stdout.strip()
    color = GREEN if svc_status == "active" else RED

    print(f"{BOLD}PVE Net Broker{RESET}")
    print(f"  Service:  {color}{svc_status}{RESET}")

    # API health
    try:
        health = api_get("/health")
        print(f"  API:      {GREEN}responding{RESET}")
        print(f"  Version:  {health['version']}")
        print(f"  Slaves:   {health['slaves_total']} total, "
              f"{GREEN}{health['slaves_available']} available{RESET}, "
              f"{YELLOW}{health['slaves_reserved']} reserved{RESET}")
    except SystemExit:
        print(f"  API:      {RED}not responding{RESET}")


def cmd_slaves():
    """List all slaves."""
    slaves = api_get("/slaves")
    if not slaves:
        print("No slaves registered. (Connect a Homey Pro via USB)")
        return

    print(f"{'ID':<12} {'IP':<14} {'STATUS':<12} {'REQUESTER':<20} {'VM IP':<14}")
    print("-" * 72)
    for s in slaves:
        status = s["status"]
        if status == "available":
            color = GREEN
        elif status == "reserved":
            color = YELLOW
        else:
            color = RED
        print(f"{s['id']:<12} {s['ip']:<14} {color}{status:<12}{RESET} "
              f"{(s.get('requester') or '-'):<20} {(s.get('vm_ip') or '-'):<14}")


def cmd_slave(slave_id: str):
    """Show slave detail."""
    slave = api_get(f"/slaves/{slave_id}")
    print(json.dumps(slave, indent=2, default=str))


def cmd_reserve(slave_id: str, requester: str, vm_ip: str):
    """Reserve a slave."""
    data, status = api_post(f"/slaves/{slave_id}/reserve", {
        "requester": requester,
        "vm_ip": vm_ip,
    })
    if status == 200:
        print(f"{GREEN}Reserved{RESET} {slave_id} → {vm_ip} (requester: {requester})")
    elif status == 409:
        detail = data.get("detail", {})
        print(f"{RED}CONFLICT:{RESET} Slave already reserved")
        print(f"  Current requester: {detail.get('requester')}")
        print(f"  VM IP: {detail.get('vm_ip')}")
        print(f"  Since: {detail.get('reserved_at')}")
    else:
        print(f"{RED}Error ({status}):{RESET} {data}")


def cmd_release(slave_id: str):
    """Release a slave."""
    data, status = api_post(f"/slaves/{slave_id}/release")
    if status == 200:
        print(f"{GREEN}Released{RESET} {slave_id}")
    else:
        print(f"{RED}Error ({status}):{RESET} {data}")


def cmd_logs(follow: bool = False):
    """Show logs."""
    cmd = ["journalctl", "-u", "pve-net-broker", "--no-pager", "-n", "50"]
    if follow:
        cmd.append("-f")
    os.execvp("journalctl", cmd)


def cmd_restart():
    """Restart service."""
    subprocess.run(["systemctl", "restart", "pve-net-broker"])
    print("Restarted. Checking status...")
    import time
    time.sleep(1)
    cmd_status()


def cmd_nat_reload():
    """Reapply static NAT rules — convergent (flush + repopulate managed chains).

    nat-rules.sh 를 직접 호출한다. 옛 방식(`ifreload -a`)은 인터페이스 스탠자가 안 바뀌면
    post-up 훅을 재실행 안 해(변경감지) 레포 수정이 라이브에 반영 안 되거나, 여러 번 돌며
    중복을 쌓았다. 스크립트의 up 은 전용 체인을 flush 후 재적재하므로 몇 번을 돌려도 결과가
    항상 레포와 동일하게 수렴한다(고아·중복 불가). 동적 USB 예약 룰은 별도 체인이라 안 건드림.
    """
    script = "/etc/network/nat-rules.sh"
    result = subprocess.run(["bash", script, "up"], capture_output=True, text=True)
    if result.returncode == 0:
        print(f"{GREEN}NAT rules reapplied (convergent){RESET}")
    else:
        print(f"{RED}Failed:{RESET} {result.stderr}")


def cmd_dhcp_reload():
    """Install repo DHCP config into /etc/dhcp, validate, restart isc-dhcp-server.

    dhcpd is AppArmor-confined to /etc/dhcp, so the configs are COPIED here
    (a symlink to /opt/... is denied by AppArmor). The git repo stays the
    source of truth; this command deploys it.
    """
    import shutil
    repo = "/opt/pve-net-broker/network"
    for name in ("dhcpd.conf", "dhcp-hosts.conf"):
        src = f"{repo}/{name}"
        dst = f"/etc/dhcp/{name}"
        if not os.path.isfile(src):
            print(f"{RED}Missing source:{RESET} {src}")
            sys.exit(1)
        # Replace an old symlink, or back up a first-time original real file.
        if os.path.islink(dst):
            os.remove(dst)
        elif os.path.isfile(dst) and not os.path.exists(dst + ".bak"):
            shutil.copyfile(dst, dst + ".bak")
        shutil.copyfile(src, dst)

    check = subprocess.run(
        ["dhcpd", "-t", "-cf", "/etc/dhcp/dhcpd.conf"],
        capture_output=True, text=True,
    )
    if check.returncode != 0:
        print(f"{RED}dhcpd.conf syntax error — not restarting:{RESET}")
        print(check.stderr.strip())
        sys.exit(1)
    result = subprocess.run(
        ["systemctl", "restart", "isc-dhcp-server"],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        print(f"{GREEN}dhcp config installed & valid → isc-dhcp-server restarted{RESET}")
    else:
        print(f"{RED}Restart failed:{RESET} {result.stderr.strip()}")
        sys.exit(1)


def cmd_proxy_deploy():
    """Deploy reverse-proxy nginx routing conf to the reverse-proxy VM over SSH.

    이 레포는 L7 라우팅(nginx conf)만 소유한다. 포털 UI(frontend)는 별도 GitLab 레포
    (swp-iot-portal-frontend)로 분리돼 .42 의 portal-frontend 계정이 build/serve 한다.
    .42 에서 nginx 는 riaveda 홈의 conf 를 심볼릭으로 로드:
      /etc/nginx/sites-enabled/reverse-proxy.conf -> {STAGE}/nginx/reverse-proxy.conf
    그리고 `location /` 는 /var/www/reverse-proxy 심볼릭이 가리키는 곳(현재
    /home/portal-frontend/portal/dist)을 서빙한다 (이 심볼릭은 .42 에서 1회 repoint).
    So deploy = rsync repo/nginx → {STAGE}/nginx (권한 불필요), then `nginx -t && reload` needs root.
    Configurable via env vars:
      PROXY_HOST   (default 10.10.10.42)                 내부망 IP
      PROXY_USER   (default riaveda)                     .42는 root 로그인 불가
      PROXY_STAGE  (default /home/riaveda/reverse-proxy) nginx가 심볼릭으로 물린 폴더
      PROXY_SUDO   (default "sudo")                      reload에 붙일 명령 (없으면 "")
    """
    host = os.getenv("PROXY_HOST", "10.10.10.42")
    user = os.getenv("PROXY_USER", "riaveda")
    stage = os.getenv("PROXY_STAGE", "/home/riaveda/reverse-proxy")
    sudo = os.getenv("PROXY_SUDO", "sudo")
    target = f"{user}@{host}"
    repo = "/opt/pve-net-broker/reverse-proxy"

    ssh = ["ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=10", target]
    # reload는 sudo 비번 프롬프트 가능성 → tty 허용
    ssh_tty = ["ssh", "-t", "-o", "ConnectTimeout=10", target]

    print(f"{CYAN}Deploy:{RESET} {target}  stage={stage}")

    # 1) SSH 연결 확인 (키 인증)
    r = subprocess.run(ssh + ["true"], capture_output=True, text=True)
    if r.returncode != 0:
        print(f"{RED}SSH 실패:{RESET} {target}")
        print(f"  {r.stderr.strip()}")
        print(f"  → PVE에서 키 배포: ssh-copy-id {target}")
        sys.exit(1)

    # 2) nginx conf 를 홈 폴더(=nginx가 심볼릭으로 읽는 곳)로 rsync — 권한 불필요
    #    --delete: 레포에서 지운 파일은 서버에서도 제거 (레포=서버 완전 미러).
    #    frontend/html 은 여기서 배포하지 않는다 — 포털은 GitLab 레포 +
    #    .42 portal-frontend 계정(build/serve) 소관.
    subprocess.run(ssh + [f"mkdir -p {stage}/nginx"],
                   capture_output=True, text=True)
    rs = subprocess.run(
        ["rsync", "-a", "--delete", f"{repo}/nginx/", f"{target}:{stage}/nginx/"],
        capture_output=True, text=True,
    )
    if rs.returncode != 0:
        print(f"{RED}rsync nginx 실패:{RESET} {rs.stderr.strip()}")
        sys.exit(1)

    # 3) 문법검증 후 reload (root 필요). NOPASSWD 아니면 sudo 비번 물어봄.
    remote = f"{sudo} nginx -t && {sudo} systemctl reload nginx".strip()
    res = subprocess.run(ssh_tty + [remote])
    if res.returncode != 0:
        print(f"{RED}nginx -t/reload 실패 — 위 출력 확인 (reload 안 됨){RESET}")
        sys.exit(1)
    print(f"{GREEN}reverse-proxy 배포 완료 → {host} (nginx reloaded){RESET}")


def _pve_guest_ids(list_cmd):
    """`qm list` / `pct list` 첫 컬럼(VMID) 추출 — 헤더 스킵. 미설치·실패는 빈 목록."""
    r = subprocess.run(list_cmd, capture_output=True, text=True)
    if r.returncode != 0:
        return []
    ids = []
    for line in r.stdout.splitlines()[1:]:   # skip header row
        parts = line.split()
        if parts and parts[0].isdigit():
            ids.append(parts[0])
    return ids


def cmd_tz_apply():
    """Set timezone (default Asia/Seoul) on the PVE host + all VMs/CTs — idempotent.

    새 VM/CT 는 기본 UTC 로 시작하므로, 온보딩 후 한 번 돌리면 전 노드가 같은 TZ 로 수렴한다
    (이미 맞는 노드는 no-op). 호스트는 root 라 직접, VM 은 qemu-guest-agent(`qm guest exec`),
    CT 는 `pct exec` 로 들어간다. guest-agent 없는 VM 은 SKIP(SSH 로 수동 — 지어내 실패시키지 않음).
    timedatectl 은 /etc/localtime 을 디스크에 써 영구다(재부팅 무관 — 이 명령은 '유실 복구'가 아니라
    '새 노드 온보딩 자동화'용). 앱 도커 컨테이너는 자체 TZ(compose)라 이 작업과 무관.
    env `PNB_TZ` 로 타임존 변경 가능(기본 Asia/Seoul).
    """
    tz = os.getenv("PNB_TZ", "Asia/Seoul")
    print(f"{CYAN}tz apply:{RESET} {tz}")

    # 1) PVE host (root — sudo 불요)
    r = subprocess.run(["timedatectl", "set-timezone", tz], capture_output=True, text=True)
    if r.returncode == 0:
        print(f"  {GREEN}✓ host{RESET} → {tz}")
    else:
        print(f"  {RED}✗ host FAILED:{RESET} {r.stderr.strip()}")

    # 2) QEMU VMs — guest-agent 로 진입 (없으면 SKIP)
    for vid in _pve_guest_ids(["qm", "list"]):
        ping = subprocess.run(["qm", "agent", vid, "ping"], capture_output=True, text=True)
        if ping.returncode != 0:
            print(f"  {YELLOW}· VM {vid} SKIP{RESET} (guest-agent 없음/꺼짐 → SSH 로 수동)")
            continue
        ex = subprocess.run(
            ["qm", "guest", "exec", vid, "--", "timedatectl", "set-timezone", tz],
            capture_output=True, text=True)
        ok = ex.returncode == 0
        print(f"  {GREEN + '✓' if ok else RED + '✗'} VM {vid}{RESET} "
              f"{'→ ' + tz if ok else 'FAILED: ' + ex.stderr.strip()}")

    # 3) LXC CTs — pct exec (systemd 없으면 localtime 심링크 fallback)
    for cid in _pve_guest_ids(["pct", "list"]):
        ex = subprocess.run(
            ["pct", "exec", cid, "--", "timedatectl", "set-timezone", tz],
            capture_output=True, text=True)
        if ex.returncode != 0:
            ex = subprocess.run(
                ["pct", "exec", cid, "--", "ln", "-sf",
                 f"/usr/share/zoneinfo/{tz}", "/etc/localtime"],
                capture_output=True, text=True)
        ok = ex.returncode == 0
        print(f"  {GREEN + '✓' if ok else RED + '✗'} CT {cid}{RESET} "
              f"{'→ ' + tz if ok else 'FAILED'}")

    print(f"{GREEN}done{RESET} — 재부팅 불요. agent 없는 VM 은 위 SKIP 을 SSH 로 수동 적용.")


def cmd_version():
    health = api_get("/health")
    print(f"pnbctl / pve-net-broker v{health['version']}")


def usage():
    print(f"""{BOLD}pnbctl{RESET} — PVE Net Broker CLI

{CYAN}Usage:{RESET}
  pnbctl status                          Service & slave summary
  pnbctl slaves                          List all slaves
  pnbctl slave <id>                      Slave detail
  pnbctl reserve <id> <requester> <ip>   Reserve a slave
  pnbctl release <id>                    Release a slave
  pnbctl logs [-f]                       Service logs
  pnbctl restart                         Restart service
  pnbctl nat reload                      Reload static NAT rules
  pnbctl dhcp reload                     Validate & reload DHCP fixed-IP config
  pnbctl proxy deploy                    Deploy reverse-proxy nginx conf to .42
  pnbctl tz apply                        Set Asia/Seoul on host + all VMs/CTs (idempotent)
  pnbctl version                         Show version
""")


def main():
    args = sys.argv[1:]
    if not args:
        usage()
        sys.exit(0)

    cmd = args[0]

    if cmd == "status":
        cmd_status()
    elif cmd == "slaves":
        cmd_slaves()
    elif cmd == "slave" and len(args) >= 2:
        cmd_slave(args[1])
    elif cmd == "reserve" and len(args) >= 4:
        cmd_reserve(args[1], args[2], args[3])
    elif cmd == "release" and len(args) >= 2:
        cmd_release(args[1])
    elif cmd == "logs":
        cmd_logs(follow="-f" in args)
    elif cmd == "restart":
        cmd_restart()
    elif cmd == "nat" and len(args) >= 2 and args[1] == "reload":
        cmd_nat_reload()
    elif cmd == "dhcp" and len(args) >= 2 and args[1] == "reload":
        cmd_dhcp_reload()
    elif cmd == "proxy" and len(args) >= 2 and args[1] == "deploy":
        cmd_proxy_deploy()
    elif cmd == "tz" and len(args) >= 2 and args[1] == "apply":
        cmd_tz_apply()
    elif cmd == "version":
        cmd_version()
    else:
        usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
