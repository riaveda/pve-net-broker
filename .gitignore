# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Data (runtime state)
data/

# 개발자별 개인 스택 라우트 — 호스트에서 nginx-route.sh 가 생성하는 런타임 상태.
# git 이력에 안 쌓이게 ignore(공유 브랜치·main 오염 방지). 배포는 proxy deploy 의 rsync 가
# working tree 를 보내므로 커밋 불필요. .gitkeep 만 추적해 빈 디렉터리 보존.
reverse-proxy/nginx/dev-routes/*.conf

# 활성 HTTPS(:443) server 블록 — tls-available/<...>.conf 를 여기로 복사해 켠다(런타임 상태).
# dev-routes 와 동일 이유로 ignore. .gitkeep 만 추적. (tls-available/ 은 커밋됨 — 원본 템플릿.)
reverse-proxy/nginx/tls-enabled/*.conf

# 브라우저 https 유도 활성화 플래그 — redirect-available/on.conf 를 여기로 복사해 켠다(런타임 상태).
reverse-proxy/nginx/redirect-enabled/*.conf

# TLS 인증서·키 — 사내 CA 루트/leaf 개인키는 "외부 주입 자산"이라 git 에 절대 올리지 않는다.
# gen-certs.sh 가 여기 생성 → 루트 crt 는 PC 배포, leaf 는 .42:/etc/nginx/ssl/ 로 배치.
reverse-proxy/ssl/

# Environment secrets
.env
systemd/pve-net-broker.env

# OS
.DS_Store
*.swp

# IDE
.vscode/
.idea/
